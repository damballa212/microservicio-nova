# ============================================================
# NOVA AI - Variables de Entorno para Dokploy
# ============================================================
# Copia este contenido en el panel "Environment" de Dokploy.
# Las variables marcadas con *** son OBLIGATORIAS.

# === Redis (servicio interno de Dokploy) ===
# Formato: redis://default:<REDIS_PASSWORD>@redis:6379
# Usar el nombre del servicio "redis" definido en docker-compose.yml
REDIS_URL=redis://default:changeme@redis:6379         # *** Cambia 'changeme' por tu password
REDIS_PASSWORD=changeme                               # *** Debe coincidir con REDIS_URL

# === LLM Principal (Google Gemini) ===
GOOGLE_API_KEY=AIza-your-google-api-key-here          # *** REQUERIDO - Sin esto el chatbot NO funciona

# === OpenAI (Whisper + GPT-4 Vision) ===
OPENAI_API_KEY=sk-your-openai-api-key-here            # *** REQUERIDO para audio/imágenes
OPENAI_BASE_URL=https://api.openai.com/v1             # Opcional: cambiar por OpenRouter si deseas

# === Chatwoot (CRM de mensajería) ===
CHATWOOT_BASE_URL=https://tu-chatwoot.tudominio.com   # *** URL de tu instancia de Chatwoot
CHATWOOT_API_TOKEN=your-chatwoot-api-token            # *** Token de API de Chatwoot
CHATWOOT_ACCOUNT_ID=1                                 # *** ID de tu cuenta en Chatwoot

# === Flowify / Outbound Webhook ===
FLOWIFY_BASE_URL=https://tu-flowify.tudominio.com     # *** URL real de Flowify (sin trailing slash)
OUTBOUND_WEBHOOK_PATH=/webhooks/n8n/nova              # Path del webhook (por defecto está bien)
N8N_WEBHOOK_SECRET=your-secret-here                   # Secreto HMAC para firma del webhook

# === Dashboard URL (IMPORTANTE para Next.js) ===
# Esta URL es la del servicio nova-api en Dokploy (la asignas en Domains)
NEXT_PUBLIC_API_URL=https://nova-api.tudominio.com    # *** URL pública de la API (sin trailing slash)

# === Servidor ===
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=production                                # *** Cambiar a production en Dokploy

# === PostgreSQL / Supabase (RAG + Memoria) ===
POSTGRES_URL=postgresql://user:password@host:5432/db?sslmode=require  # *** Tu PostgreSQL con pgvector
PG_SCHEMA=rag

# === Memoria Conversacional ===
MEMORY_WINDOW_SIZE=4
BUFFER_WAIT_SECONDS=10

# === Logging ===
LOG_LEVEL=INFO

# === Seguridad ===
ENCRYPTION_KEY=your-fernet-key-here                  # *** Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# === RAG - Cohere Reranker (Opcional) ===
COHERE_API_KEY=                                       # Opcional: mejora calidad de búsqueda RAG

# === CORS (Producción) ===
# En producción, especifica los dominios permitidos separados por coma
CORS_ALLOWED_ORIGINS=https://nova-dashboard.tudominio.com,https://tu-flowify.tudominio.com

# === Observabilidad Phoenix/OpenTelemetry (Opcional) ===
PHOENIX_ENABLED=false
PHOENIX_PROJECT_NAME=nova-ai
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:4317
PHOENIX_PROTOCOL=grpc
PHOENIX_AUTO_INSTRUMENT=true
PHOENIX_BATCH=true
